# npm-Guardian Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# These same values must be set in Vercel Dashboard → Settings → Environment Variables.

# Supabase (Server-side — used by API routes only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase (Client-side — exposed to the browser, safe for anon key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# GitHub OAuth (for future OAuth integration)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
